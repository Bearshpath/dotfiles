# ----------Windows Rules------------


#GLOBAL
windowrule = tile on, match:class .*



#--KITTY--
# Force Kitty to be 30% transparent (0.7) and always tile
windowrule = opacity 1 1, match:class ^(kitty)$
windowrule = tile on, match:class ^(kitty)$
windowrule {
	name = kitty
	dim_around = off
	match:class = kitty
}



# IDK about this
resize_on_border = false



#--Firefox--
# Force Firefox to always open at a specific large size (1200x800)
windowrule = size 1200 800, match:class ^(firefox)$
windowrule = center 1, match:class ^(firefox)$



#--Stickynote app--

windowrule = workspace special:research, match:class ^(ResearchBoard)$
windowrule = float 1, match:class ^(ResearchBoard)$
windowrule = size 400 400, match:class ^(ResearchBoard)$
#windowrule = center on, match:class ^(ResearchBoard)$
windowrule = move 1095 460, match:class ^(ResearchBoard)$



#--Xpad stiky notes application--
windowrule = float 1, match:class ^(xpad)$



